{
	"name": "@foomo/contentfultree",
	"version": "1.0.0",
	"type": "module",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"files": [
		"dist",
		"README.md",
		"LICENSE"
	],
	"author": "foomo",
	"license": "MIT",
	"scripts": {
		"clean": "rm -f ./tsconfig.tsbuildinfo && rm -rvf dist",
		"build": "tsc -b",
		"rebuild": "pnpm clean && pnpm build",
		"dev": "pnpm tsc -b tsconfig.json -w",
		"lint": "biome check --write ."
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.13",
		"@contentful/app-sdk": "4.56.0",
		"@types/react": "19.2.14",
		"typescript": "6.0.3"
	},
	"peerDependencies": {
		"@contentful/app-sdk": ">=4",
		"contentful-management": ">=12",
		"react": ">=18"
	}
}
